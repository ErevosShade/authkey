{
    "manifest_version": 3,
    "name": "AuthKey",
    "version": "0.0.1",
    "description": "A simple extension to manage your passwords.",
    "permissions": ["storage", "tabs", "scripting", "activeTab"],
    "host_permissions": ["*://*/*"],
    "options_page":"options.html",
    "action": {
        "default_popup": "popup.html"
        
    }
}